{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "File Rename Pro",
  "version": "0.3.0",
  "identifier": "com.aoaochan.file-rename-pro",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "File Rename Pro",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright (c) 2026 aoaochan",
    "publisher": "aoaochan",
    "shortDescription": "A lightweight desktop application for batch renaming files.",
    "longDescription": "A lightweight desktop application for batch renaming files."
  }
}
